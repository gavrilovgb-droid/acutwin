# AcuTwin — переменные окружения
# Скопируйте в .env и заполните реальными значениями.
# Файл .env добавлен в .gitignore и НИКОГДА не коммитится.

# ── Врачебный Telegram-бот ─────────────────────────────────
# Уведомления администратору: новые заявки на триал, новые онлайн-записи.
TELEGRAM_BOT_TOKEN=<токен врачебного бота от @BotFather>
TELEGRAM_CHAT_ID=<chat_id получателя — узнать через @userinfobot>

# ── Пациентский Telegram-бот (@AcuTwinRemindBot) ───────────
# Напоминания пациентам: за 24 часа и за 1 час до приёма.
# Бот регистрирует webhook на https://<домен>/tg-patient при старте.
PATIENT_TG_BOT_TOKEN=<токен пациентского бота от @BotFather>
PATIENT_TG_BOT_NAME=AcuTwinRemindBot

# ── Email (Resend.com) ─────────────────────────────────────
# Используется для: выдачи учётных данных, email-напоминаний за день до приёма.
RESEND_API_KEY=<API key с resend.com>

# ── Litestream (резервное копирование БД → Backblaze B2) ───
LITESTREAM_BUCKET=acutwin-litestream
LITESTREAM_REGION=us-east-005
LITESTREAM_ENDPOINT=https://s3.us-east-005.backblazeb2.com
LITESTREAM_ACCESS_KEY=<keyID из Backblaze B2>
LITESTREAM_SECRET_KEY=<applicationKey из Backblaze B2>
